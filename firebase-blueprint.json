{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["dokter", "wali_asuh", "wali_kelas", "kepala_sekolah", "guru_mapel", "wali_asrama"] },
        "name": { "type": "string" },
        "mapel": { "type": "string" },
        "fcmToken": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "IzinSakit": {
      "title": "Izin Sakit",
      "description": "Sick leave permit for students",
      "type": "object",
      "properties": {
        "nomor_surat": { "type": "string" },
        "nama_siswa": { "type": "string" },
        "kelas": { "type": "string" },
        "diagnosa": { "type": "string" },
        "jumlah_hari": { "type": "number" },
        "tgl_mulai": { "type": "string", "format": "date-time" },
        "tgl_selesai": { "type": "string", "format": "date-time" },
        "tgl_surat": { "type": "string", "format": "date-time" },
        "lokasi": { "type": "string" },
        "nama_dokter": { "type": "string" },
        "nama_wali_kelas": { "type": "string" },
        "catatan_kamar": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_asuh", "pending_kelas", "approved"] },
        "dokter_uid": { "type": "string" },
        "wali_asuh_uid": { "type": "string" },
        "wali_kelas_uid": { "type": "string" }
      },
      "required": ["nomor_surat", "nama_siswa", "kelas", "diagnosa", "jumlah_hari", "tgl_mulai", "tgl_selesai", "tgl_surat", "status"]
    },
    "PinjamHP": {
      "title": "Pinjam HP",
      "description": "Phone borrowing records for students",
      "type": "object",
      "properties": {
        "nama_siswa": { "type": "string" },
        "kelas": { "type": "string" },
        "keperluan": { "type": "string" },
        "tgl_pinjam": { "type": "string", "format": "date-time" },
        "tgl_kembali": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["dipinjam", "dikembalikan"] },
        "wali_asuh_name": { "type": "string" },
        "wali_asuh_uid": { "type": "string" }
      },
      "required": ["nama_siswa", "kelas", "keperluan", "tgl_pinjam", "status", "wali_asuh_uid"]
    },
    "Siswa": {
      "title": "Siswa",
      "description": "Student master data",
      "type": "object",
      "properties": {
        "nik": { "type": "string" },
        "nomor_kk": { "type": "string" },
        "nama_lengkap": { "type": "string" },
        "kelas": { "type": "string" },
        "tempat_lahir": { "type": "string" },
        "tanggal_lahir": { "type": "string" },
        "umur": { "type": "number" },
        "jenis_kelamin": { "type": "string" },
        "agama": { "type": "string" },
        "kecamatan": { "type": "string" },
        "kelurahan": { "type": "string" },
        "alamat": { "type": "string" },
        "rt": { "type": "string" },
        "rw": { "type": "string" },
        "anak_ke": { "type": "number" },
        "saudara": { "type": "number" },
        "ayah": { "type": "string" },
        "ibu": { "type": "string" }
      },
      "required": ["nik", "nama_lengkap", "kelas"]
    },
    "LaptopRequest": {
      "title": "Laptop Request",
      "description": "Information about laptop loan requests for students",
      "type": "object",
      "properties": {
        "nomor_surat": { "type": "string" },
        "tgl_request": { "type": "string", "format": "date-time" },
        "guru_name": { "type": "string" },
        "guru_uid": { "type": "string" },
        "mapel": { "type": "string" },
        "kelas": { "type": "string" },
        "daftar_siswa": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["nomor_surat", "tgl_request", "guru_name", "guru_uid", "mapel", "kelas", "daftar_siswa", "status"]
    },
    "AppNotification": {
      "title": "App Notification",
      "description": "System notifications for users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "readBy": { "type": "array", "items": { "type": "string" } },
        "recipientRoles": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" }
      },
      "required": ["title", "description", "type", "createdAt", "readBy", "recipientRoles"]
    },
    "HPRequest": {
      "title": "HP Request",
      "description": "Information about group phone loan requests for students",
      "type": "object",
      "properties": {
        "nomor_surat": { "type": "string" },
        "tgl_request": { "type": "string", "format": "date-time" },
        "guru_name": { "type": "string" },
        "guru_uid": { "type": "string" },
        "mapel": { "type": "string" },
        "kelas": { "type": "string" },
        "daftar_siswa": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "processed"] }
      },
      "required": ["nomor_surat", "tgl_request", "guru_name", "guru_uid", "mapel", "kelas", "daftar_siswa", "status"]
    },
    "HealthCheckProposal": {
      "title": "Health Check Proposal",
      "description": "Proposal for health check by wali asrama",
      "type": "object",
      "properties": {
        "proposer_name": { "type": "string" },
        "proposer_uid": { "type": "string" },
        "asrama": { "type": "string" },
        "tgl_usulan": { "type": "string", "format": "date-time" },
        "daftar_siswa": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "processed"] },
        "keterangan": { "type": "string" }
      },
      "required": ["proposer_name", "proposer_uid", "asrama", "tgl_usulan", "daftar_siswa", "status"]
    },
    "MadingPost": {
      "title": "Mading Post",
      "description": "School bulletin board post",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "authorName": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorRole": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "authorName", "authorUid", "authorRole", "createdAt"]
    },
    "ProgressRecord": {
      "title": "Progress Record",
      "description": "Student progress and development records",
      "type": "object",
      "properties": {
        "nama_siswa": { "type": "string" },
        "kelas": { "type": "string" },
        "isi_catatan": { "type": "string" },
        "author_name": { "type": "string" },
        "author_uid": { "type": "string" },
        "author_role": { "type": "string" },
        "tgl_catatan": { "type": "string", "format": "date-time" },
        "is_acknowledged": { "type": "boolean" }
      },
      "required": ["nama_siswa", "kelas", "isi_catatan", "author_name", "author_uid", "author_role", "tgl_catatan"]
    },
    "Agenda": {
      "title": "Agenda",
      "description": "School agenda and events with role-based visibility",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "author_name": { "type": "string" },
        "author_uid": { "type": "string" },
        "author_role": { "type": "string" },
        "sharedWith": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "author_name", "author_uid", "author_role", "sharedWith", "createdAt"]
    },
    "WallMessage": {
      "title": "Wall Message",
      "description": "Messages left on role-specific interaction walls",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "author_name": { "type": "string" },
        "author_uid": { "type": "string" },
        "author_role": { "type": "string" },
        "wall_type": { "type": "string", "enum": ["asrama", "asuh", "kelas"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "author_name", "author_uid", "author_role", "wall_type", "createdAt"]
    },
    "EvaluationNote": {
      "title": "Evaluation Note",
      "description": "Daily evaluation notes from wali asrama",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "author_name": { "type": "string" },
        "author_uid": { "type": "string" },
        "asrama": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["description", "date", "author_name", "author_uid", "asrama", "createdAt"]
    },
    "SarprasReport": {
      "title": "Sarpras Report",
      "description": "Dormitory facilities and infrastructure damage reports",
      "type": "object",
      "properties": {
        "asrama": { "type": "string" },
        "item_name": { "type": "string" },
        "damage_description": { "type": "string" },
        "location": { "type": "string" },
        "author_name": { "type": "string" },
        "author_uid": { "type": "string" },
        "tgl_lapor": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "on_progress", "fixed"] }
      },
      "required": ["asrama", "item_name", "damage_description", "location", "author_name", "author_uid", "tgl_lapor", "status"]
    },
    "Ketidakhadiran": {
      "title": "Ketidakhadiran",
      "description": "Student absence tracking reports for activities and class KBM",
      "type": "object",
      "properties": {
        "nomor_surat": { "type": "string" },
        "tgl_absen": { "type": "string", "format": "date-time" },
        "keterangan_kegiatan": { "type": "string" },
        "kelas": { "type": "string" },
        "daftar_siswa": { "type": "array", "items": { "type": "string" } },
        "deskripsi": { "type": "string" },
        "author_name": { "type": "string" },
        "author_uid": { "type": "string" },
        "author_role": { "type": "string", "enum": ["wali_asuh", "wali_asrama"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nomor_surat", "tgl_absen", "keterangan_kegiatan", "kelas", "daftar_siswa", "deskripsi", "author_name", "author_uid", "author_role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/izin_sakit/{permitId}": {
      "schema": "IzinSakit",
      "description": "Sick leave permits"
    },
    "/pinjam_hp/{pinjamId}": {
      "schema": "PinjamHP",
      "description": "Phone borrowing records"
    },
    "/siswa/{siswaId}": {
      "schema": "Siswa",
      "description": "Student master data"
    },
    "/notifications/{notifId}": {
      "schema": "AppNotification",
      "description": "System-wide notifications"
    },
    "/laptop_requests/{requestId}": {
      "schema": "LaptopRequest",
      "description": "Laptop loan requests initiated by subject teachers"
    },
    "/hp_requests/{requestId}": {
      "schema": "HPRequest",
      "description": "Group phone loan requests initiated by subject teachers or wali asuh"
    },
    "/health_check_proposals/{proposalId}": {
      "schema": "HealthCheckProposal",
      "description": "Health check proposals initiated by wali asrama"
    },
    "/mading/{postId}": {
      "schema": "MadingPost",
      "description": "School bulletin board posts"
    },
    "/progress_records/{recordId}": {
      "schema": "ProgressRecord",
      "description": "Student progress records"
    },
    "/sarpras_reports/{reportId}": {
      "schema": "SarprasReport",
      "description": "Dormitory facilities and infrastructure damage reports"
    },
    "/agendas/{agendaId}": {
      "schema": "Agenda",
      "description": "School agenda and events"
    },
    "/wall_messages/{messageId}": {
      "schema": "WallMessage",
      "description": "Messages left on role-specific interaction walls"
    },
    "/evaluation_notes/{noteId}": {
      "schema": "EvaluationNote",
      "description": "Daily evaluation notes created by wali asrama"
    },
    "/ketidakhadiran/{khId}": {
      "schema": "Ketidakhadiran",
      "description": "Activity level and class-level attendance tracking and absence records"
    }
  }
}
