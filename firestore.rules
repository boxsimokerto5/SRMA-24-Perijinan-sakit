rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: ['dokter', 'wali_asuh', 'wali_kelas', 'kepala_sekolah'])
    //   - name: string (optional)
    //   - fcmToken: string (optional)
    //
    // Collection: izin_sakit
    // Document ID: {permitId}
    // Fields:
    //   - tipe: string (required, enum: ['sakit', 'umum', 'catatan'])
    //   - nomor_surat: string (required)
    //   - nama_siswa: string (required)
    //   - kelas: string (required)
    //   - diagnosa: string (optional, for tipe sakit)
    //   - alasan: string (optional, for tipe umum)
    //   - isi_catatan: string (optional, for tipe catatan)
    //   - jumlah_hari: number (optional)
    //   - tgl_mulai: timestamp (optional)
    //   - tgl_selesai: timestamp (optional)
    //   - tgl_surat: timestamp (required)
    //   - tgl_disetujui: timestamp (optional)
    //   - lokasi: string (optional)
    //   - nama_dokter: string (optional)
    //   - nama_wali_kelas: string (required)
    //   - nama_wali_asuh: string (optional)
    //   - catatan_kamar: string (optional)
    //   - status: string (required, enum: ['pending_asuh', 'pending_kelas', 'approved', 'pending_ack', 'acknowledged'])
    //   - dokter_uid: string (optional)
    //   - wali_asuh_uid: string (optional)
    //   - wali_kelas_uid: string (optional)
    // Collection: memorandums
    // Document ID: {memoId}
    // Fields:
    //   - nomor_memo: string (required)
    //   - perihal: string (required)
    //   - isi: string (required)
    //   - tgl_memo: timestamp (required)
    //   - penerima: list (required, elements: ['dokter', 'wali_asuh', 'wali_kelas'])
    //   - pengirim_name: string (required)
    //   - pengirim_uid: string (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isValidIzinSakit(data) {
      return data.nomor_surat is string &&
             data.nama_siswa is string &&
             data.kelas is string &&
             data.tgl_surat is timestamp &&
             data.status in ['pending_asuh', 'pending_kelas', 'approved', 'pending_ack', 'acknowledged'] &&
             (data.tipe == 'sakit' || data.tipe == 'umum' || data.tipe == 'catatan');
    }

    function isValidMemorandum(data) {
      return data.nomor_memo is string &&
             data.perihal is string &&
             data.isi is string &&
             data.tgl_memo is timestamp &&
             data.penerima is list &&
             data.pengirim_uid is string;
    }

    function isValidPinjamHP(data) {
      return data.nama_siswa is string &&
             data.kelas is string &&
             data.keperluan is string &&
             data.tgl_pinjam is timestamp &&
             data.status in ['dipinjam', 'dikembalikan'] &&
             data.wali_asuh_uid is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      // Allow users to read their own profile or allow others to read roles for logic
      allow read: if isAuthenticated();
      // Allow users to create their own profile on first login
      allow create: if isOwner(uid) && request.resource.data.role in ['dokter', 'wali_asuh', 'wali_kelas', 'kepala_sekolah'];
      // Only allow updating non-role fields unless admin
      allow update: if isOwner(uid) && request.resource.data.role == resource.data.role;
    }

    match /izin_sakit/{permitId} {
      // All authenticated users can read permits
      allow read: if isAuthenticated();

      // Create rules
      allow create: if isAuthenticated() && isValidIzinSakit(request.resource.data) && (
        // Dokter can create sickness permits
        (hasRole('dokter') && 
         request.resource.data.tipe == 'sakit' &&
         request.resource.data.status == 'pending_asuh' &&
         request.resource.data.dokter_uid == request.auth.uid) ||
        
        // Wali Asuh can create general permits
        (hasRole('wali_asuh') && 
         request.resource.data.tipe == 'umum' &&
         request.resource.data.status == 'pending_kelas' &&
         request.resource.data.wali_asuh_uid == request.auth.uid) ||

        // Wali Kelas can create student notes
        (hasRole('wali_kelas') &&
         request.resource.data.tipe == 'catatan' &&
         request.resource.data.status == 'pending_ack' &&
         request.resource.data.wali_kelas_uid == request.auth.uid)
      );

      // Update rules based on role
      allow update: if isAuthenticated() && (
        // Wali Asuh can update catatan_kamar and move to pending_kelas
        (hasRole('wali_asuh') && 
         resource.data.status == 'pending_asuh' &&
         request.resource.data.status == 'pending_kelas' &&
         request.resource.data.diff(resource.data).affectedKeys().hasAny(['catatan_kamar', 'status', 'wali_asuh_uid', 'nama_wali_asuh'])) ||
        
        // Wali Kelas can approve
        (hasRole('wali_kelas') && 
         resource.data.status == 'pending_kelas' &&
         request.resource.data.status == 'approved' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'wali_kelas_uid'])) ||
        
        // Wali Asuh can acknowledge student notes
        (hasRole('wali_asuh') &&
         resource.data.status == 'pending_ack' &&
         request.resource.data.status == 'acknowledged' &&
         request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'wali_asuh_uid', 'nama_wali_asuh', 'tgl_disetujui'])) ||

        // Allow Dokter and Wali Asuh to add to the actions log
        ((hasRole('dokter') || hasRole('wali_asuh')) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tindakan']))
      );

      // No one can delete for audit purposes
      allow delete: if false;
    }

    match /memorandums/{memoId} {
      allow read: if isAuthenticated() && (
        hasRole('kepala_sekolah') || 
        getUserData().role in resource.data.penerima
      );
      allow create: if hasRole('kepala_sekolah') && 
                    isValidMemorandum(request.resource.data) &&
                     request.resource.data.pengirim_uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /pinjam_hp/{pinjamId} {
      allow read: if isAuthenticated();
      allow create: if hasRole('wali_asuh') && 
                    isValidPinjamHP(request.resource.data) &&
                    request.resource.data.wali_asuh_uid == request.auth.uid;
      allow update: if hasRole('wali_asuh') && 
                    request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'tgl_kembali']);
      allow delete: if false;
    }

    match /siswa/{siswaId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('kepala_sekolah');
    }
  }
}
