rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: ['dokter', 'wali_asuh', 'wali_kelas'])
    //   - name: string (optional)
    //   - fcmToken: string (optional)
    //
    // Collection: izin_sakit
    // Document ID: {permitId}
    // Fields:
    //   - nomor_surat: string (required)
    //   - nama_siswa: string (required)
    //   - kelas: string (required)
    //   - diagnosa: string (required)
    //   - jumlah_hari: number (required)
    //   - tgl_mulai: timestamp (required)
    //   - tgl_selesai: timestamp (required)
    //   - tgl_surat: timestamp (required)
    //   - lokasi: string (required)
    //   - nama_dokter: string (required)
    //   - nama_wali_kelas: string (required)
    //   - catatan_kamar: string (optional)
    //   - status: string (required, enum: ['pending_asuh', 'pending_kelas', 'approved'])
    //   - dokter_uid: string (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isValidIzinSakit(data) {
      return data.nomor_surat is string &&
             data.nama_siswa is string &&
             data.kelas is string &&
             data.diagnosa is string &&
             data.jumlah_hari is number &&
             data.tgl_mulai is timestamp &&
             data.tgl_selesai is timestamp &&
             data.tgl_surat is timestamp &&
             data.status in ['pending_asuh', 'pending_kelas', 'approved'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      // Allow users to read their own profile or allow others to read roles for logic
      allow read: if isAuthenticated();
      // Allow users to create their own profile on first login
      allow create: if isOwner(uid) && request.resource.data.role in ['dokter', 'wali_asuh', 'wali_kelas'];
      // Only allow updating non-role fields unless admin
      allow update: if isOwner(uid) && request.resource.data.role == resource.data.role;
    }

    match /izin_sakit/{permitId} {
      // All authenticated users can read permits
      allow read: if isAuthenticated();

      // Only Dokter can create permits
      allow create: if hasRole('dokter') && 
                      isValidIzinSakit(request.resource.data) &&
                      request.resource.data.status == 'pending_asuh' &&
                      request.resource.data.dokter_uid == request.auth.uid;

      // Update rules based on role
      allow update: if isAuthenticated() && (
        // Wali Asuh can update catatan_kamar and move to pending_kelas
        (hasRole('wali_asuh') && 
         resource.data.status == 'pending_asuh' &&
         request.resource.data.status == 'pending_kelas' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['catatan_kamar', 'status', 'wali_asuh_uid', 'nama_wali_asuh'])) ||
        
        // Wali Kelas can approve
        (hasRole('wali_kelas') && 
         resource.data.status == 'pending_kelas' &&
         request.resource.data.status == 'approved' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'wali_kelas_uid']))
      );

      // No one can delete for audit purposes
      allow delete: if false;
    }
  }
}
