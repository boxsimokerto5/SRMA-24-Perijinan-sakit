rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net (Pillar 6)
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Pillar 3: Primitive Definitions & Reusable Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && (request.auth.token.email_verified == true || isMasterAdmin()); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Identity logic - Identity roles must be looked up from a trusted source
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isEmailVerified() && getUserData().role == role;
    }

    function isAdmin() {
      // Primary admin is the master admin account.
      // Secondary admin check: Any user with kepala_sekolah role.
      return isMasterAdmin() || (isSignedIn() && getUserData().role == 'kepala_sekolah');
    }
    
    function isMasterAdmin() {
      // Fastest path for system administrator - no email verification needed for emergencies
      return isSignedIn() && request.auth.token.email == "boxsimokerto5@gmail.com";
    }

    function isSystemAdmin() {
      // Emergency access for the verified developer account
      return isEmailVerified() && request.auth.token.email == "boxsimokerto5@gmail.com";
    }

    // Pillar 2: Validation Blueprints (The "Anti-Update-Gap")
     function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             data.role in ['dokter', 'wali_asuh', 'wali_kelas', 'kepala_sekolah', 'guru_mapel', 'wali_asrama'];
    }

    function isValidIzinSakit(data) {
      return data.keys().hasAll(['nomor_surat', 'nama_siswa', 'kelas', 'tgl_surat', 'status', 'tipe']) &&
             data.nomor_surat is string && data.nomor_surat.size() <= 64 &&
             data.nama_siswa is string && data.nama_siswa.size() <= 128 &&
             data.kelas is string && data.kelas.size() <= 32 &&
             data.tgl_surat == request.time &&
             data.status in ['pending_asuh', 'pending_kelas', 'approved', 'pending_ack', 'acknowledged'] &&
             data.tipe in ['sakit', 'umum', 'catatan'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'description', 'type', 'createdAt', 'readBy', 'recipientRoles']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.type in ['info', 'success', 'warning', 'error'] &&
             data.createdAt == request.time &&
             data.readBy is list && data.readBy.size() <= 500 &&
             data.recipientRoles is list && data.recipientRoles.size() > 0;
    }

    function isValidLaptopRequest(data) {
      return data.keys().hasAll(['nomor_surat', 'tgl_request', 'guru_name', 'guru_uid', 'mapel', 'kelas', 'daftar_siswa', 'status']) &&
             data.nomor_surat is string && data.nomor_surat.size() <= 64 &&
             data.guru_name is string && data.guru_name.size() <= 128 &&
             data.mapel is string && data.mapel.size() <= 64 &&
             data.kelas is string && data.kelas.size() <= 32 &&
             data.daftar_siswa is list && data.daftar_siswa.size() > 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.tgl_request == request.time;
    }

    function isValidHPRequest(data) {
      return data.keys().hasAll(['nomor_surat', 'tgl_request', 'guru_name', 'guru_uid', 'mapel', 'kelas', 'daftar_siswa', 'status']) &&
             data.nomor_surat is string && data.nomor_surat.size() <= 64 &&
             data.guru_name is string && data.guru_name.size() <= 128 &&
             data.mapel is string && data.mapel.size() <= 64 &&
             data.kelas is string && data.kelas.size() <= 32 &&
             data.daftar_siswa is list && data.daftar_siswa.size() > 0 &&
             data.status in ['pending', 'approved', 'rejected', 'processed'] &&
             data.tgl_request == request.time;
    }

    function isValidHealthCheckProposal(data) {
      return data.keys().hasAll(['proposer_name', 'proposer_uid', 'asrama', 'tgl_usulan', 'daftar_siswa', 'status']) &&
             data.proposer_name is string && data.proposer_name.size() <= 128 &&
             data.proposer_uid == request.auth.uid &&
             data.asrama is string && data.asrama.size() <= 64 &&
             data.tgl_usulan == request.time &&
             data.daftar_siswa is list && data.daftar_siswa.size() > 0 &&
             data.status in ['pending', 'processed'] &&
             (!('keterangan' in data) || (data.keterangan is string && data.keterangan.size() <= 1000));
    }

    function isValidMadingPost(data) {
      return data.content is string && data.content.size() <= 5000 &&
             (!('authorName' in data) || (data.authorName is string)) &&
             (!('authorUid' in data) || (data.authorUid is string)) &&
             (!('authorRole' in data) || (data.authorRole is string)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidProgressRecord(data) {
      return data.keys().hasAll(['nama_siswa', 'kelas', 'isi_catatan', 'author_name', 'author_uid', 'author_role', 'tgl_catatan']) &&
             data.nama_siswa is string && data.nama_siswa.size() <= 128 &&
             data.kelas is string && data.kelas.size() <= 32 &&
             data.isi_catatan is string && data.isi_catatan.size() <= 5000 &&
             data.author_name is string && data.author_name.size() <= 128 &&
             data.author_uid == request.auth.uid &&
             data.tgl_catatan == request.time &&
             (!('is_acknowledged' in data) || data.is_acknowledged is bool);
    }

    function isValidSarprasReport(data) {
      return data.keys().hasAll(['asrama', 'item_name', 'damage_description', 'location', 'author_name', 'author_uid', 'tgl_lapor', 'status']) &&
             data.asrama is string && data.asrama.size() <= 64 &&
             data.item_name is string && data.item_name.size() <= 200 &&
             data.damage_description is string && data.damage_description.size() <= 2000 &&
             data.location is string && data.location.size() <= 200 &&
             data.author_name is string && data.author_name.size() <= 128 &&
             data.author_uid == request.auth.uid &&
             data.tgl_lapor == request.time &&
             data.status in ['pending', 'on_progress', 'fixed'];
    }

    function isValidAgenda(data) {
      return data.keys().hasAll(['title', 'date', 'author_name', 'author_uid', 'author_role', 'sharedWith', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.date is timestamp &&
             data.author_name is string &&
             data.author_uid == request.auth.uid &&
             data.sharedWith is list &&
             data.createdAt == request.time;
    }

    function isValidMonthlyReport(data) {
      return data.keys().hasAll(['siswa_id', 'nama_siswa', 'kelas', 'asrama', 'wali_asuh_name', 'wali_asuh_uid', 'periode_bulan', 'berat_badan', 'tinggi_badan', 'status_kesehatan', 'catatan_kesehatan', 'ibadah_score', 'adab_score', 'kemandirian_score', 'kemandirian_level', 'karakter_deskripsi', 'akademik_deskripsi', 'ekstrakurikuler', 'capaian_khusus', 'foto_kegiatan', 'pesan_wali_asuh', 'createdAt']) &&
             data.nama_siswa is string && data.nama_siswa.size() <= 128 &&
             data.wali_asuh_uid == request.auth.uid &&
             data.createdAt == request.time &&
             data.ibadah_score >= 1 && data.ibadah_score <= 5 &&
             data.adab_score >= 1 && data.adab_score <= 5 &&
             data.kemandirian_score >= 0 && data.kemandirian_score <= 100 &&
             (data.get('video_url', '') is string) &&
             (!('foto_siswa_url' in data) || (data.foto_siswa_url is string));
    }

    function isMadingAuthor(authId) {
      return isSignedIn() && authId == request.auth.uid;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\.\\-]+$'); 
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(uid);
      allow create: if isSignedIn() && isValidId(uid) && (uid == request.auth.uid) && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(uid) && (uid == request.auth.uid) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'fcmToken', 'role', 'pfp', 'mapel']) &&
        (incoming().role == existing().role || isAdmin())
      );
    }

    match /izin_sakit/{permitId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(permitId);
      
      allow create: if isSignedIn() && isValidId(permitId) && isValidIzinSakit(incoming()) && (
        isMasterAdmin() ||
        (hasRole('dokter') && incoming().tipe == 'sakit') ||
        (hasRole('wali_asuh') && incoming().tipe == 'umum') ||
        ((hasRole('wali_kelas') || hasRole('guru_mapel')) && incoming().tipe == 'catatan') ||
        isAdmin()
      );

      allow update: if isSignedIn() && isValidId(permitId) && (
        isMasterAdmin() ||
        (hasRole('wali_asuh') && existing().status == 'pending_asuh' && incoming().status == 'pending_kelas' &&
         incoming().diff(existing()).affectedKeys().hasAny(['catatan_kamar', 'status'])) ||
         
        ((hasRole('wali_kelas') || hasRole('guru_mapel')) && existing().status == 'pending_kelas' && incoming().status == 'approved' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'wali_kelas_uid'])) ||
         
        (hasRole('wali_asuh') && existing().status == 'pending_ack' && incoming().status == 'acknowledged' &&
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'tgl_disetujui'])) ||
         
        ((hasRole('dokter') || hasRole('wali_asuh') || hasRole('wali_kelas') || hasRole('guru_mapel') || hasRole('kepala_sekolah')) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['tindakan'])) ||
         
        isAdmin()
      );

      allow delete: if isMasterAdmin() || isAdmin() || isSystemAdmin();
    }

    match /notifications/{notifId} {
      allow list: if isSignedIn() && (isMasterAdmin() || getUserData().role in resource.data.recipientRoles || isAdmin() || isSystemAdmin());
      allow get: if isSignedIn() && isValidId(notifId) && (isMasterAdmin() || getUserData().role in resource.data.recipientRoles || isAdmin() || isSystemAdmin());
      
      allow create: if isSignedIn() && isValidId(notifId) && isValidNotification(incoming());
      
      allow update: if isSignedIn() && isValidId(notifId) && (
        isMasterAdmin() ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['readBy']) && 
         incoming().readBy.hasAll(existing().readBy) &&
         incoming().readBy.size() == existing().readBy.size() + 1 &&
         incoming().readBy[incoming().readBy.size() - 1] == request.auth.uid) ||
        isAdmin()
      );
      
      allow delete: if isMasterAdmin() || isAdmin() || isSystemAdmin();
    }

    match /memorandums/{memoId} {
      allow list: if isSignedIn() && (isMasterAdmin() || hasRole('kepala_sekolah') || (getUserData().role in resource.data.penerima) || isSystemAdmin());
      allow get: if isSignedIn() && isValidId(memoId) && (isMasterAdmin() || hasRole('kepala_sekolah') || (getUserData().role in resource.data.penerima) || isSystemAdmin());
      allow create: if (isMasterAdmin() || hasRole('kepala_sekolah') || isSystemAdmin()) && isValidId(memoId) && (incoming().pengirim_uid == request.auth.uid);
      allow delete: if isMasterAdmin() || isAdmin() || isSystemAdmin();
    }

    match /pinjam_hp/{pinjamId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(pinjamId);
      allow create: if (hasRole('wali_asuh') || isAdmin()) && isValidId(pinjamId);
      allow update: if (hasRole('wali_asuh') || isAdmin()) && isValidId(pinjamId);
      allow delete: if isAdmin() || (hasRole('wali_asuh') && existing().wali_asuh_uid == request.auth.uid);
    }

    match /siswa/{siswaId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(siswaId);
      allow write: if isAdmin() || isMasterAdmin();
      allow update: if isSignedIn() && (hasRole('wali_asuh') || isAdmin() || isMasterAdmin()) &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['foto_url']);
    }

    match /announcements/{annId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(annId);
      allow create: if (isMasterAdmin() || hasRole('kepala_sekolah') || isAdmin() || isSystemAdmin()) && isValidId(annId);
      allow delete: if (isMasterAdmin() || isAdmin() || isSystemAdmin()) && isValidId(annId);
    }

    match /hp_requests/{requestId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(requestId);
      allow create: if (hasRole('guru_mapel') || hasRole('wali_asuh')) && isValidId(requestId) && isValidHPRequest(incoming());
      allow update: if (hasRole('wali_asuh') || hasRole('kepala_sekolah') || hasRole('guru_mapel') || isAdmin()) && isValidId(requestId);
      allow delete: if isAdmin() || (hasRole('guru_mapel') && existing().guru_uid == request.auth.uid);
    }
    
    match /health_check_proposals/{proposalId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(proposalId);
      allow create: if hasRole('wali_asrama') && isValidId(proposalId) && isValidHealthCheckProposal(incoming());
      allow update: if (hasRole('dokter') || hasRole('wali_asrama') || isAdmin()) && isValidId(proposalId);
      allow delete: if isAdmin() || (hasRole('wali_asrama') && existing().proposer_uid == request.auth.uid);
    }

    match /laptop_requests/{requestId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(requestId);
      allow create: if hasRole('guru_mapel') && isValidId(requestId) && isValidLaptopRequest(incoming());
      allow update: if (hasRole('wali_asuh') || hasRole('kepala_sekolah') || hasRole('guru_mapel') || isAdmin()) && isValidId(requestId);
      allow delete: if isAdmin() || (hasRole('guru_mapel') && existing().guru_uid == request.auth.uid);
    }

    match /mading/{postId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(postId);
      allow create: if isSignedIn() && isValidId(postId) &&
                    incoming().authorUid == request.auth.uid &&
                    incoming().createdAt == request.time &&
                    isValidMadingPost(incoming());
      allow update: if isSignedIn() && isValidId(postId) &&
                    (isAdmin() || (existing().authorUid == request.auth.uid)) &&
                    incoming().updatedAt == request.time &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().authorUid == existing().authorUid &&
                    isValidMadingPost(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt']);
      allow delete: if isSignedIn() && isValidId(postId) &&
                    (isAdmin() || (existing().authorUid == request.auth.uid));
    }

    match /progress_records/{recordId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(recordId);
      allow create: if (isMasterAdmin() || hasRole('guru_mapel') || hasRole('wali_kelas')) && isValidId(recordId) && isValidProgressRecord(incoming());
      allow update: if (isValidId(recordId)) && (
        isMasterAdmin() ||
        (hasRole('wali_asuh') && incoming().diff(existing()).affectedKeys().hasOnly(['is_acknowledged'])) ||
        ((hasRole('guru_mapel') || hasRole('wali_kelas')) && existing().author_uid == request.auth.uid && 
         isValidProgressRecord(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['isi_catatan', 'tgl_catatan'])) ||
        isAdmin()
      );
      allow delete: if isMasterAdmin() || isAdmin() || (isSignedIn() && existing().author_uid == request.auth.uid);
    }

    match /sarpras_reports/{reportId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(reportId);
      allow create: if hasRole('wali_asrama') && isValidId(reportId) && isValidSarprasReport(incoming());
      allow update: if isValidId(reportId) && (hasRole('wali_asrama') || hasRole('kepala_sekolah') || hasRole('wali_asuh') || isAdmin());
      allow delete: if isAdmin() || (hasRole('wali_asrama') && existing().author_uid == request.auth.uid);
    }

    match /monthly_reports/{reportId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(reportId);
      allow create: if (isMasterAdmin() || hasRole('wali_asuh')) && isValidId(reportId) && isValidMonthlyReport(incoming());
      allow delete: if isMasterAdmin() || isAdmin() || (hasRole('wali_asuh') && existing().wali_asuh_uid == request.auth.uid);
    }

    match /agendas/{agendaId} {
      allow list: if isSignedIn() && (
        hasRole('kepala_sekolah') || 
        resource.data.author_uid == request.auth.uid || 
        getUserData().role in resource.data.sharedWith
      );
      allow get: if isSignedIn() && isValidId(agendaId);
      allow create: if isSignedIn() && isValidId(agendaId) && isValidAgenda(incoming());
      allow update: if isSignedIn() && isValidId(agendaId) && (isAdmin() || existing().author_uid == request.auth.uid) && isValidAgenda(incoming());
      allow delete: if isSignedIn() && isValidId(agendaId) && (isAdmin() || existing().author_uid == request.auth.uid);
    }
  }
}
