rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net (Pillar 6)
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Pillar 3: Primitive Definitions & Reusable Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Identity logic - Identity roles must be looked up from a trusted source
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isEmailVerified() && getUserData().role == role;
    }

    function isAdmin() {
      // Allow the default admin email or anyone with the kepala_sekolah role
      return isEmailVerified() && (
        request.auth.token.email == "boxsimokerto5@gmail.com" || 
        getUserData().role == 'kepala_sekolah'
      );
    }

    // Pillar 2: Validation Blueprints (The "Anti-Update-Gap")
     function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             data.role in ['dokter', 'wali_asuh', 'wali_kelas', 'kepala_sekolah', 'guru_mapel', 'wali_asrama'];
    }

    function isValidIzinSakit(data) {
      return data.keys().hasAll(['nomor_surat', 'nama_siswa', 'kelas', 'tgl_surat', 'status', 'tipe']) &&
             data.nomor_surat is string && data.nomor_surat.size() <= 64 &&
             data.nama_siswa is string && data.nama_siswa.size() <= 128 &&
             data.kelas is string && data.kelas.size() <= 32 &&
             data.tgl_surat == request.time &&
             data.status in ['pending_asuh', 'pending_kelas', 'approved', 'pending_ack', 'acknowledged'] &&
             data.tipe in ['sakit', 'umum', 'catatan'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'description', 'type', 'createdAt', 'readBy', 'recipientRoles']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.type in ['info', 'success', 'warning', 'error'] &&
             data.createdAt == request.time &&
             data.readBy is list && data.readBy.size() <= 500 &&
             data.recipientRoles is list && data.recipientRoles.size() > 0;
    }

    function isValidLaptopRequest(data) {
      return data.keys().hasAll(['nomor_surat', 'tgl_request', 'guru_name', 'guru_uid', 'mapel', 'kelas', 'daftar_siswa', 'status']) &&
             data.nomor_surat is string && data.nomor_surat.size() <= 64 &&
             data.guru_name is string && data.guru_name.size() <= 128 &&
             data.mapel is string && data.mapel.size() <= 64 &&
             data.kelas is string && data.kelas.size() <= 32 &&
             data.daftar_siswa is list && data.daftar_siswa.size() > 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.tgl_request == request.time;
    }

    function isValidHPRequest(data) {
      return data.keys().hasAll(['nomor_surat', 'tgl_request', 'guru_name', 'guru_uid', 'mapel', 'kelas', 'daftar_siswa', 'status']) &&
             data.nomor_surat is string && data.nomor_surat.size() <= 64 &&
             data.guru_name is string && data.guru_name.size() <= 128 &&
             data.mapel is string && data.mapel.size() <= 64 &&
             data.kelas is string && data.kelas.size() <= 32 &&
             data.daftar_siswa is list && data.daftar_siswa.size() > 0 &&
             data.status in ['pending', 'approved', 'rejected', 'processed'] &&
             data.tgl_request == request.time;
    }

    function isValidHealthCheckProposal(data) {
      return data.keys().hasAll(['proposer_name', 'proposer_uid', 'asrama', 'tgl_usulan', 'daftar_siswa', 'status']) &&
             data.proposer_name is string && data.proposer_name.size() <= 128 &&
             data.proposer_uid == request.auth.uid &&
             data.asrama is string && data.asrama.size() <= 64 &&
             data.tgl_usulan == request.time &&
             data.daftar_siswa is list && data.daftar_siswa.size() > 0 &&
             data.status in ['pending', 'processed'] &&
             (!('keterangan' in data) || (data.keterangan is string && data.keterangan.size() <= 1000));
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (uid == request.auth.uid) && isValidUser(incoming());
      allow update: if isSignedIn() && (uid == request.auth.uid) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'fcmToken', 'role', 'pfp']) &&
        (incoming().role == existing().role || isAdmin())
      );
    }

    match /izin_sakit/{permitId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isValidIzinSakit(incoming()) && (
        (hasRole('dokter') && incoming().tipe == 'sakit') ||
        (hasRole('wali_asuh') && incoming().tipe == 'umum') ||
        ((hasRole('wali_kelas') || hasRole('guru_mapel')) && incoming().tipe == 'catatan') ||
        isAdmin()
      );

      allow update: if isSignedIn() && (
        (hasRole('wali_asuh') && existing().status == 'pending_asuh' && incoming().status == 'pending_kelas' &&
         incoming().diff(existing()).affectedKeys().hasAny(['catatan_kamar', 'status'])) ||
         
        ((hasRole('wali_kelas') || hasRole('guru_mapel')) && existing().status == 'pending_kelas' && incoming().status == 'approved' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'wali_kelas_uid'])) ||
         
        (hasRole('wali_asuh') && existing().status == 'pending_ack' && incoming().status == 'acknowledged' &&
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'tgl_disetujui'])) ||
         
        ((hasRole('dokter') || hasRole('wali_asuh') || hasRole('wali_kelas') || hasRole('guru_mapel') || hasRole('kepala_sekolah')) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['tindakan'])) ||
         
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow list: if isSignedIn() && (getUserData().role in resource.data.recipientRoles || isAdmin());
      allow get: if isSignedIn() && (getUserData().role in resource.data.recipientRoles || isAdmin());
      
      allow create: if isSignedIn() && isValidNotification(incoming());
      
      allow update: if isSignedIn() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['readBy']) && 
         incoming().readBy.hasAll(existing().readBy) &&
         incoming().readBy.size() == existing().readBy.size() + 1 &&
         incoming().readBy[incoming().readBy.size() - 1] == request.auth.uid) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /memorandums/{memoId} {
      allow read: if isSignedIn() && (hasRole('kepala_sekolah') || (getUserData().role in resource.data.penerima));
      allow create: if hasRole('kepala_sekolah') && (incoming().pengirim_uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /pinjam_hp/{pinjamId} {
      allow read: if isSignedIn();
      allow create: if hasRole('wali_asuh') || isAdmin();
      allow update: if hasRole('wali_asuh') || isAdmin();
      allow delete: if isAdmin();
    }

    match /siswa/{siswaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /announcements/{annId} {
      allow read: if isSignedIn();
      allow create: if hasRole('kepala_sekolah') || isAdmin();
      allow delete: if isAdmin();
    }

    match /hp_requests/{requestId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        hasRole('kepala_sekolah') || 
        hasRole('wali_asuh') || 
        (hasRole('guru_mapel') && resource.data.guru_uid == request.auth.uid) ||
        isAdmin()
      );
      allow create: if (hasRole('guru_mapel') || hasRole('wali_asuh')) && isValidHPRequest(incoming());
      allow update: if (hasRole('wali_asuh') || hasRole('kepala_sekolah') || hasRole('guru_mapel') || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /health_check_proposals/{proposalId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        hasRole('dokter') || 
        hasRole('wali_asrama') || 
        isAdmin()
      );
      allow create: if hasRole('wali_asrama') && isValidHealthCheckProposal(incoming());
      allow update: if (hasRole('dokter') || hasRole('wali_asrama') || isAdmin());
      allow delete: if isAdmin();
    }

    match /laptop_requests/{requestId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        hasRole('kepala_sekolah') || 
        hasRole('wali_asuh') || 
        (hasRole('guru_mapel') && resource.data.guru_uid == request.auth.uid) ||
        isAdmin()
      );
      allow create: if hasRole('guru_mapel') && isValidLaptopRequest(incoming());
      allow update: if (hasRole('wali_asuh') || hasRole('kepala_sekolah') || hasRole('guru_mapel') || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
